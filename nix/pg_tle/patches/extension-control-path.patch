From 3a2553ad738c14bfbeebe3981a17a6cf53d3dc2f Mon Sep 17 00:00:00 2001
From: Raminder Singh <romi_ssk@yahoo.co.in>
Date: Wed, 22 Jul 2026 10:45:25 +0530
Subject: [PATCH] feat: add support for extension_control_path GUC

The extension_control_path GUC allows admins to configure a colon separated list
of directories where Postgres looks for extensions to load. This patch adds the
same support to pg_tle. Without this patch pg_tle itself was not loaded because
it looked at standard extension path (sharedir) to look for the control files
when loading an extension (including itself). If you are thinking how can pg_tle
itself play a part it loading before it's loaded, then the answer is that it's
added to shared_preload_libraries so it starts hooking the create extension
commands at startup.
---
 src/tleextension.c | 86 ++++++++++++++++++++++++++++++++++++++++------
 1 file changed, 76 insertions(+), 10 deletions(-)

diff --git a/src/tleextension.c b/src/tleextension.c
index 272a13a..37e9838 100644
--- a/src/tleextension.c
+++ b/src/tleextension.c
@@ -573,15 +573,77 @@ is_extension_script_filename(const char *filename)
 		(strncmp(extension, TLE_EXT_SQL_SUFFIX, sizeof(TLE_EXT_SQL_SUFFIX)) == 0);
 }
 
+ /* 
+ * Finds the correct extension base directory given an extension name.
+ * The base directory contains the control file for the given extension
+ * at the <basedir>/extension/<extname>.control location. To find this
+ * directory, the function first looks inside the directories listed in
+ * the extension_control_path GUC one by one and returns the first one
+ * that has the extensions's control file. The extension_control_path
+ * contains potential extension paths separated by colons. A single path
+ * can either point to a location on the file system or be $system which
+ * resolves to Postgres sharedir location. If none of the paths contain
+ * the control file, it return the sharepath. The caller is responsible
+ * for calling pfree on the returned string.
+ */
 static char *
-pg_tle_get_extension_control_directory(void)
+pg_tle_find_extension_control_directory(const char *extname)
 {
 	char		sharepath[MAXPGPATH];
-	char	   *result;
+	char	   *ecp;
+	char	   *path;
+	char	   *saveptr;
+	char	   *result = NULL;
 
 	get_share_path(my_exec_path, sharepath);
+
+	if (Extension_control_path == NULL || strlen(Extension_control_path) == 0) {
+		ecp = pstrdup("$system");
+	} else {
+		ecp = pstrdup(Extension_control_path);
+	}
+
+	for (path = strtok_r(ecp, ":", &saveptr); path != NULL;
+		 path = strtok_r(NULL, ":", &saveptr))
+	{
+		const char *basedir = (strcmp(path, "$system") == 0) ? sharepath : path;
+		char	   *control_file;
+
+		control_file = psprintf("%s/extension/%s.control",
+								   basedir, extname);
+
+		if (filestat(control_file))
+		{
+			result = pstrdup(basedir);
+			pfree(control_file);
+			break;
+		}
+
+		pfree(control_file);
+	}
+
+	pfree(ecp);
+
+	if (result == NULL)
+	{
+		return pstrdup(sharepath);
+	}
+	else
+	{
+		return result;
+	}
+}
+
+static char *
+pg_tle_get_extension_control_directory(const char *extname)
+{
+	char *result;
+	char *control_directory = pg_tle_find_extension_control_directory(extname);
+
 	result = (char *) palloc(MAXPGPATH);
-	snprintf(result, MAXPGPATH, "%s/extension", sharepath);
+	snprintf(result, MAXPGPATH, "%s/extension", control_directory);
+
+	pfree(control_directory);
 
 	return result;
 }
@@ -603,12 +665,13 @@ static char *
 get_extension_control_filename_for_file(const char *extname)
 {
 	char	   *result;
-	char		sharepath[MAXPGPATH];
+	char *control_directory = pg_tle_find_extension_control_directory(extname);
 
-	get_share_path(my_exec_path, sharepath);
 	result = (char *) palloc(MAXPGPATH);
 	snprintf(result, MAXPGPATH, "%s/extension/%s.control",
-			 sharepath, extname);
+			 control_directory, extname);
+
+	pfree(control_directory);
 
 	return result;
 }
@@ -616,22 +679,25 @@ get_extension_control_filename_for_file(const char *extname)
 static char *
 get_extension_script_directory(ExtensionControlFile *control)
 {
-	char		sharepath[MAXPGPATH];
 	char	   *result;
+	char	   *control_directory;
 
 	/*
 	 * The directory parameter can be omitted, absolute, or relative to the
 	 * installation's share directory.
 	 */
 	if (!control->directory)
-		return pg_tle_get_extension_control_directory();
+		return pg_tle_get_extension_control_directory(control->name);
 
 	if (is_absolute_path(control->directory))
 		return pstrdup(control->directory);
 
-	get_share_path(my_exec_path, sharepath);
+	control_directory = pg_tle_find_extension_control_directory(control->name);
+
 	result = (char *) palloc(MAXPGPATH);
-	snprintf(result, MAXPGPATH, "%s/%s", sharepath, control->directory);
+	snprintf(result, MAXPGPATH, "%s/%s", control_directory, control->directory);
+
+	pfree(control_directory);
 
 	return result;
 }
